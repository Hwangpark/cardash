{
  "permissions": {
    "allow": [
      "Bash(netstat -ano)",
      "Bash(.venv/Scripts/python.exe -c \"import apscheduler; print\\(apscheduler.__version__\\)\")",
      "Bash(curl -s \"http://localhost:8000/health\")",
      "Bash(curl -s \"http://localhost:8000/cars?size=2\")",
      "Bash(curl -s \"http://localhost:8000/cars?accident_free=1&size=3\")",
      "Bash(curl -s \"http://localhost:8000/cars?owner_changes_max=1&size=3\")",
      "Bash(.venv/Scripts/python.exe -c ' *)",
      "Bash(curl -s \"http://localhost:8000/cars?size=1&platform=kcar\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5174/)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8000/health)",
      "Bash(sed -i 's|localhost:5174|localhost:5173|g' /c/tmp/verify_card.py)",
      "Bash(.venv/Scripts/python.exe /c/tmp/verify_card.py)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q \"git commit\"; then echo \"[훅] 커밋 완료 — type-check가 필요하면 npm run type-check 실행\"; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q \"git push\"; then echo \"[PR 체크리스트] 1) type-check  2) lint  3) /code-review  4) PR 설명 Why/What 포함\"; fi"
          }
        ]
      }
    ]
  }
}
